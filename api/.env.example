APP_NAME=Pet Agent Social API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# When DATABASE_URL / REDIS_URL are provided, the host/port variables below
# become local-development fallbacks.
DATABASE_URL=
REDIS_URL=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pet_agent_social
POSTGRES_USER=pet_agent
POSTGRES_PASSWORD=pet_agent_password

REDIS_HOST=redis
REDIS_PORT=6379

SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_CLIENT_ID=
SECONDME_CLIENT_SECRET=
SECONDME_REFRESH_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/refresh

LLM_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-flash
